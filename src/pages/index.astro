---
import '@fontsource-variable/inter/wght.css'
import '@fontsource-variable/inter/wght-italic.css'
import SpaceHome from '../components/SpaceHome.vue'
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="theme-color" content="#06091a" />
    <meta
      name="description"
      content="BookOrbit is a self-hosted library and reading platform for ebooks, audiobooks, and comics."
    />
    <link rel="canonical" href="https://bookorbit.app/" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="BookOrbit" />
    <meta property="og:title" content="BookOrbit - Your reading space" />
    <meta
      property="og:description"
      content="A self-hosted library and reading platform for ebooks, audiobooks, comics, and PDFs."
    />
    <meta property="og:url" content="https://bookorbit.app/" />
    <meta property="og:image" content="https://bookorbit.app/images/home/dashboard-overview.webp" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="719" />
    <meta property="og:image:alt" content="BookOrbit dashboard with reading statistics and book shelves" />
    <meta name="twitter:card" content="summary_large_image" />
    <title>BookOrbit - Your reading space</title>
  </head>
  <body>
    <SpaceHome client:load />
  </body>
</html>

<style is:global>
  html,
  body {
    margin: 0;
    background: #050914;
  }
</style>
